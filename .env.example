# ============================================================
# Edeviser — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================

# --- Client-side (VITE_ prefix — exposed to browser) --------

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/publishable key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry DSN for error monitoring (optional — omit to disable)
VITE_SENTRY_DSN=

# Demo-account password (local / staging ONLY). When set, the login page
# shows a "Quick Demo Access" panel that signs in with the seeded demo
# users. Leave empty in production so the panel is hidden and the literal
# never ships in the client bundle.
VITE_DEMO_PASSWORD=

# --- Server-side (Vercel env vars for cron API routes) ------

# Supabase project URL (same as VITE_SUPABASE_URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key — NEVER expose to client
# (Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret for authenticating Vercel cron requests
CRON_SECRET=your-cron-secret

# --- Edge Function secrets (set via `supabase secrets set`) --

# Resend API key for transactional email
# RESEND_API_KEY=re_xxxxxxxx

# AI provider key (one of these, depending on provider)
# OPENAI_API_KEY=sk-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- CI / GitHub Actions secrets -------------------------

# Sentry release upload
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=edeviser

# Supabase CLI (for type generation in CI)
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
