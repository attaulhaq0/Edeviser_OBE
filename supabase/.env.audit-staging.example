# Example environment file for the audit-fixtures Edge Function.
#
# Copy this to supabase/.env.audit-staging and fill in the values for a
# staging-only Supabase project. NEVER set ENV_ID=production here — the
# endpoint refuses to serve traffic outside audit-staging on purpose.
#
# Usage (local):
#   supabase functions serve audit-fixtures \
#     --env-file supabase/.env.audit-staging
#
# Usage (deploy): see docs/operations/audit-fixtures-deploy.md (Task 2.4).

ENV_ID=audit-staging
SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me
