# Dependencies
node_modules/

# Build output
dist/

# Vercel local project linking (contains project/org IDs — not for the repo)
.vercel/

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
!.vscode/settings.json
.idea/

# Kiro MCP settings (may contain API keys — never commit)
.kiro/settings/mcp.json

# Git worktrees managed by Claude Code (never commit these — they contain
# per-worktree .git link files that git misreads as phantom submodules in CI)
.claude/worktrees/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
nul

# TypeScript build info
tsconfig.tsbuildinfo
*.tsbuildinfo

# Coverage reports
coverage/

# Local diagnostic output (lint/tsc/test runs)
tsc_*.txt
lint_*.txt
test_*.txt

# Playwright / test output
playwright-report/
test-results/

# Pre-deployment audit output (artifacts from audit runs; baselines are committed)
audit/output/

# Signed waivers — gitignored so signed production-deploy waivers can't be
# leaked via the repo. The committed template is audit/waivers.example.json.
audit/waivers.json

# Local prototype folder — reference UI scaffolded by hand, not part of the app
loginsignup/

# Demo capture media (rendered videos, audio, frames, screenshots, slides) —
# generated locally via the demo:* scripts, kept local only, never committed
docs/demo-capture/

# Generated business/demo documents — kept local only, not committed to the repo
docs/business/EDEVISER-BUSINESS-PLAN.html
docs/business/EDEVISER-DEMO-STORYBOARD.html
docs/pdf/business/EDEVISER-BUSINESS-PLAN.pdf
docs/pdf/business/EDEVISER-DEMO-STORYBOARD.pdf

# Local QA reference PDFs (manual test captures / Google-Docs exports) — kept local only
docs/pdf/QA/
docs/pdf/Student Profile - Google Docs.pdf
