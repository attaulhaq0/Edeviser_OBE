# Auto-detect text files and normalize to LF in the repo.
* text=auto eol=lf

# Force LF for files that MUST be LF at checkout regardless of core.autocrlf
# (shell scripts will not run on WSL/macOS/Linux if they have CR characters)
*.sh           text eol=lf
*.bash         text eol=lf

# Cross-platform config files that benefit from consistent LF
*.yml          text eol=lf
*.yaml         text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf
.editorconfig  text eol=lf

# PowerShell can run with either, but pwsh prefers LF
*.ps1          text eol=lf

# Treat these as binary (no line-ending or diff handling)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
